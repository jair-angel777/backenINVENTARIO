generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model productos {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  nombre              String
  categoria           String?
  precio              Float
  costo               Float?
  stock               Int       @default(0)
  stock_minimo        Int?      @default(5)
  sku                 String?   @unique(map: "sku")
  imagen              String?
  proveedor_id        String?   @db.ObjectId
  fecha_creacion      DateTime? @default(now())
  fecha_actualizacion DateTime? @default(now())
}

model proveedores {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  nombre         String
  email          String?
  telefono       String?
  direccion      String?
  categoria      String?
  notas          String?
  fecha_creacion DateTime? @default(now())
}

model orden_compra {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  proveedor_id   String          @db.ObjectId
  fecha          DateTime        @default(now())
  subtotal       Float           @default(0)
  igv            Float           @default(0)
  total          Float
  estado         String          @default("PENDIENTE") // PENDIENTE, COMPLETADO, CANCELADO
  notas          String?
  detalles       detalle_orden[]
}

model detalle_orden {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  orden_id        String       @db.ObjectId
  producto_id     String       @db.ObjectId
  nombre_producto String
  cantidad        Int
  costo_unitario  Float
  subtotal        Float
  orden           orden_compra @relation(fields: [orden_id], references: [id])
}
